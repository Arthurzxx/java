 public static void main(String[] args) {
        int[] vetor = {5, 12, 8, 20, 7, 3, 15};
        int valorProcurado = 8; 
        
        boolean encontrado = false;
        
    
        for (int num : vetor) {
            if (num == valorProcurado) {
                encontrado = true;
                break; 
            }
        }
        
        
        if (encontrado) {
            System.out.println(valorProcurado + " está presente no vetor.");
        } else {
            System.out.println(valorProcurado + " não está presente no vetor.");
        }
    }
}
