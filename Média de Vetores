public static void main(String[] args) {
        int[] vetor = {10, 20, 30, 40, 50};
        int soma = 0;
        
      
        for (int num : vetor) {
            System.out.println(num); 
            soma += num;             
        }
        
        System.out.println("Média: " + (double)soma / vetor.length);
    }
}
}
